{
  "name": "foxy-music-desktop",
  "version": "1.0.0",
  "description": "Foxy Music — Application de streaming desktop",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.12",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "me.thefoxy.music",
    "productName": "Foxy Music",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "protocols": [
      {
        "name": "Foxy Music",
        "schemes": ["foxymusic"]
      }
    ]
  }
}
